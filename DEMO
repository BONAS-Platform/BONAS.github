const NetworkIllustration = ({ isFaultActive, riskLevel, optStrategy }) => {
  const getGlowColor = () => {
    if (riskLevel > 70) return "fill-red-900/20 stroke-red-500";
    if (riskLevel > 30) return "fill-amber-900/20 stroke-amber-500";
    return "fill-indigo-900/20 stroke-indigo-500";
  };
  
  const getParticleSpeed = () => {
      if (optStrategy === 'EXTREMUM') return "0.5s";
      if (optStrategy === 'HEURISTIC') return "4s";
      return riskLevel > 50 ? "1s" : "2s"; // PID default
  }

  return (
    <div className="absolute inset-0 overflow-hidden opacity-20 pointer-events-none">
      <svg className="w-full h-full preserve-3d">
        <defs>
          <filter id="glow">
            <feGaussianBlur stdDeviation="2.5" result="coloredBlur" />
            <feMerge>
              <feMergeNode in="coloredBlur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>
        <line x1="20%" y1="50%" x2="50%" y2="20%" stroke="#4f46e5" strokeWidth="1" />
        <line x1="80%" y1="50%" x2="50%" y2="20%" stroke="#4f46e5" strokeWidth="1" />
        <line x1="20%" y1="50%" x2="50%" y2="80%" stroke="#4f46e5" strokeWidth="1" />
        <line x1="80%" y1="50%" x2="50%" y2="80%" stroke="#4f46e5" strokeWidth="1" />
        <circle r="3" fill="#fff" filter="url(#glow)">
          <animateMotion dur={getParticleSpeed()} repeatCount="indefinite" path="M 200 300 L 500 120" />
        </circle>
        <circle r="3" fill="#fff" filter="url(#glow)">
          <animateMotion dur={getParticleSpeed()} repeatCount="indefinite" path="M 800 300 L 500 120" />
        </circle>
        <circle cx="50%" cy="50%" r="40" fill="url(#centerGrad)" filter="url(#glow)" className={`${getGlowColor()} ${isFaultActive ? 'animate-pulse' : ''}`} strokeWidth="2" />
        <radialGradient id="centerGrad">
          <stop offset="0%" stopColor="#4f46e5" stopOpacity="0.5" />
          <stop offset="100%" stopColor="#1e1b4b" stopOpacity="0" />
        </radialGradient>
      </svg>
    </div>
  );
};

// --- MOCK DATA ---
const generateTimeLabel = () => {
  const d = new Date();
  return `${d.getHours().toString().padStart(2,'0')}:${d.getMinutes().toString().padStart(2,'0')}:${d.getSeconds().toString().padStart(2,'0')}`;
};

export default function BonasNexus() {
  // --- VIEWPORT STATE ---
  const [isMobileMode, setIsMobileMode] = useState(false);

  // --- APP STATE ---
  const [activeTab, setActiveTab] = useState('dashboard');
  const [agents, setAgents] = useState([]);
  const [logs, setLogs] = useState([]);
  const [apiKey, setApiKey] = useState('');
  const [showSettings, setShowSettings] = useState(false);

  // DEV STUDIO STATE
  const [agentTemplates, setAgentTemplates] = useState([
    { id: 'nrg-01', name: 'EnergyMiner', type: 'OPTIMIZER', target: 'Grid Power', cost: 5, rewardRate: 2.5, color: '#10b981', creator: 'System', royalty: 0 },
    { id: 'lat-99', name: 'LatencyKiller', type: 'DIAGNOSTIC', target: 'Network I/O', cost: 8, rewardRate: 4.0, color: '#3b82f6', creator: 'System', royalty: 0 },
    { id: 'sql-opt', name: 'QueryTuner', type: 'HARVESTER', target: 'Postgres DB', cost: 2, rewardRate: 1.2, color: '#f59e0b', creator: 'System', royalty: 0 },
  ]);

  const [ePurse, setEPurse] = useState({
    liquid: 1250.00,
    staked: 500.00,
    escrow: 150.00,
    totalMined: 3420.50,
    gasBurned: 120.40
  });

  // --- SLA, STOCHASTIC & OPTIMIZATION STATE ---
  const [efficiencyData, setEfficiencyData] = useState([]);
  const [isFaultActive, setIsFaultActive] = useState(false);
  const [stochasticRisk, setStochasticRisk] = useState(12); 
  const [slaTarget, setSlaTarget] = useState(85); 
  const [activeBounties, setActiveBounties] = useState([]);
  
  const [optStrategy, setOptStrategy] = useState('PID'); 
  
  const [faultStartTime, setFaultStartTime] = useState(null);
  const [mttr, setMttr] = useState(4.2); 
  const [anomalies, setAnomalies] = useState([
    { id: 1, time: '10:42:15', component: 'HVAC-04', issue: 'Thermal Drift', status: 'RESOLVED' }
  ]);

  const [selectedTemplate, setSelectedTemplate] = useState(null);
  const [selectedActiveAgent, setSelectedActiveAgent] = useState(null); 
  const [showDepositModal, setShowDepositModal] = useState(false);
  const [showExchangeModal, setShowExchangeModal] = useState(false);
  const [depositAmount, setDepositAmount] = useState('');
  const [exchangeAmount, setExchangeAmount] = useState('');

  const [aiPrompt, setAiPrompt] = useState('');
  const [isGeneratingAgent, setIsGeneratingAgent] = useState(false);
  const [aiAnalysis, setAiAnalysis] = useState(null);
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [logSummary, setLogSummary] = useState(null);
  const [isSummarizing, setIsSummarizing] = useState(false);
  const [strategyAdvice, setStrategyAdvice] = useState(null);
  const [isStrategizing, setIsStrategizing] = useState(false);
  
  const [manualAgent, setManualAgent] = useState({
    name: '', type: 'OPTIMIZER', target: '', cost: 5, rewardRate: 2.0, color: '#6366f1', royalty: 5, logic: 'function evaluate(telemetry) {\n  return telemetry.entropy > 0.8;\n}'
  });
  const [isTestingEbot, setIsTestingEbot] = useState(false);
  const [isBuildingManual, setIsBuildingManual] = useState(false);
  const [logFilter, setLogFilter] = useState('ALL');

  const logEndRef = useRef(null);

  // --- CORE LOGIC ---
  const addLog = (source, message, type = 'INFO') => {
    const newLog = { id: `${Date.now()}-${Math.random().toString(36).substr(2, 9)}`, time: generateTimeLabel(), source, message, type };
    setLogs(prev => [newLog, ...prev].slice(0, 150));
  };

  const BonasAPI = {
    logRequest: (method, endpoint, status = 200) => {
        addLog('API-GATEWAY', `${method} https://api.bonas.io/v1${endpoint} [${status}]`, 'INFO');
    },
    async registerEbotIP(payload) {
        this.logRequest('POST', '/dev/mint-ip', 201);
        return new Promise(resolve => setTimeout(resolve, 1500));
    },
    async deployAgent(payload) {
        this.logRequest('POST', '/agents/deploy', 202);
        return new Promise(resolve => setTimeout(resolve, 800)); 
    },
    async stakeTokens(amount, purpose) {
        this.logRequest('POST', '/wallet/stake', 201);
        return new Promise(resolve => setTimeout(resolve, 500));
    },
    async retireAgent(agentId) {
        this.logRequest('DELETE', `/agents/${agentId}`, 200);
        return new Promise(resolve => setTimeout(resolve, 500));
    },
    connectStream() {
        addLog('SYSTEM', 'Connecting to wss://api.bonas.io/v1/stream/live...', 'INFO');
        setTimeout(() => addLog('SYSTEM', 'WebSocket Connected. Listening for Stochastic Events.', 'SUCCESS'), 1000);
    }
  };

  useEffect(() => {
    const storedKey = localStorage.getItem('bonas_gemini_key');
    if (storedKey) setApiKey(storedKey);
    BonasAPI.logRequest('POST', '/auth/login', 200);
    BonasAPI.connectStream();

    const handleResize = () => {
      if (window.innerWidth < 768) setIsMobileMode(true);
    };
    window.addEventListener('resize', handleResize);
    handleResize();
    return () => window.removeEventListener('resize', handleResize);
  }, []);

  const saveApiKey = (key) => {
    setApiKey(key);
    localStorage.setItem('bonas_gemini_key', key);
    setShowSettings(false);
    addLog('SYSTEM', 'API Key updated successfully.', 'SUCCESS');
  };

  // --- ACTIONS ---
  const deployAgent = async (template) => {
    if (ePurse.liquid < template.cost) {
        addLog('EPURSE', `Deployment failed: Insufficient liquid OPS.`, 'ERROR');
        return;
    }
    
    let currentRewardRate = template.rewardRate;
    if (activeBounties.length > 0) {
        addLog('SMART-CONTRACT', `Bounty claimed! Network volatility premium applied.`, 'SUCCESS');
        setActiveBounties(prev => prev.slice(1)); 
        currentRewardRate *= 1.5; 
    }

    await BonasAPI.stakeTokens(template.cost, "AGENT_DEPLOYMENT_BOND");
    await BonasAPI.deployAgent({ templateId: template.id, name: template.name });

    setEPurse(prev => ({ ...prev, liquid: prev.liquid - template.cost, staked: prev.staked + template.cost }));
    const newAgent = { 
        ...template, 
        rewardRate: currentRewardRate,
        instanceId: `${template.id || 'gen'}-${Math.floor(Math.random()*1000)}`, 
        status: 'BOOTING', 
        uptime: 0, 
        earned: 0,
        spent: 0, 
        level: 1 
    };
    
    setAgents(prev => [...prev, newAgent]);
    addLog('NEXUS', `Deploying ${newAgent.name}...`, 'INFO');
    
    setTimeout(() => {
        setAgents(prev => prev.map(a => a.instanceId === newAgent.instanceId ? { ...a, status: 'ACTIVE' } : a));
        addLog(newAgent.name, 'Connected to Telemetry Stream.', 'SUCCESS');
    }, 2000);
  };

  const handleRetireAgent = async (agent) => {
      await BonasAPI.retireAgent(agent.instanceId);
      setAgents(prev => prev.filter(a => a.instanceId !== agent.instanceId));
      setEPurse(prev => ({ ...prev, staked: prev.staked - agent.cost, liquid: prev.liquid + agent.cost }));
      addLog('NEXUS', `Retired ${agent.name}. Bond returned.`, 'INFO');
      setSelectedActiveAgent(null);
  };

  const injectFault = () => {
    if(!isFaultActive) {
        setIsFaultActive(true);
        setFaultStartTime(Date.now());
        addLog('SIMUVERSE', 'CRITICAL ALERT: Physical Entropy Detected (Markov S2 Transition).', 'ERROR');
        setAnomalies(prev => [{ id: Date.now(), time: generateTimeLabel(), component: 'Dynamic Node', issue: 'System Entropy Spike', status: 'ACTIVE' }, ...prev.slice(0, 4)]);
    }
  };

  const handleTestAndMint = async () => {
    const mintCost = 25; 
    if (ePurse.liquid < mintCost) {
        addLog('DEV-STUDIO', 'Mint failed: Insufficient liquid OPS for IP Registration (25 OPS required).', 'ERROR');
        return;
    }

    setIsTestingEbot(true);
    addLog('DEV-STUDIO', 'Simulating logic boundaries in sandbox environment...', 'INFO');
    
    setTimeout(async () => {
        addLog('DEV-STUDIO', 'Simulation passed. SLA thresholds verified.', 'SUCCESS');
        addLog('SMART-CONTRACT', 'Initiating ebot IP tokenization on-chain...', 'INFO');
        
        await BonasAPI.registerEbotIP(manualAgent);

        setEPurse(prev => ({...prev, liquid: prev.liquid - mintCost, gasBurned: prev.gasBurned + mintCost}));
        
        const newTemplate = {
            id: `dev-${Date.now().toString().slice(-4)}`,
            name: manualAgent.name || "Custom Agent",
            type: manualAgent.type,
            target: manualAgent.target || "General",
            cost: Number(manualAgent.cost),
            rewardRate: Number(manualAgent.rewardRate),
            color: manualAgent.color,
            creator: 'Local Dev (You)',
            royalty: Number(manualAgent.royalty)
        };
        
        setAgentTemplates(prev => [...prev, newTemplate]);
        addLog('DEV-STUDIO', `Successfully tokenized ${newTemplate.name} IP. Added to Forge.`, 'SUCCESS');
        setIsTestingEbot(false);
        setIsBuildingManual(false);
    }, 2000);
  };

  const handleManualSurge = () => {
      const surgeCost = 50;
      if (ePurse.liquid < surgeCost) {
          addLog('OPTIMIZATION', 'Surge Failed: Insufficient OPS balance.', 'ERROR');
          return;
      }
      setEPurse(prev => ({...prev, liquid: prev.liquid - surgeCost, gasBurned: prev.gasBurned + surgeCost}));
      addLog('OPTIMIZATION', `Manual Surge Executed (-${surgeCost} OPS). Flushing system entropy...`, 'SUCCESS');
      
      setIsFaultActive(false);
      setStochasticRisk(Math.max(12, stochasticRisk - 40));
      setEfficiencyData(prev => {
          const newData = [...prev, { time: generateTimeLabel(), efficiency: 100, baseline: slaTarget }];
          if (newData.length > 20) newData.shift();
          return newData;
      });
      if (faultStartTime) {
          setFaultStartTime(null);
          setAnomalies(prev => prev.map(a => a.status === 'ACTIVE' ? {...a, status: 'RESOLVED'} : a));
      }
  };

  const handleDeposit = async () => {
    if (!depositAmount) return;
    const amount = parseFloat(depositAmount);
    addLog('BRIDGE', 'Initiating Fiat-to-Token Bridge...', 'INFO');
    setEPurse(prev => ({ ...prev, liquid: prev.liquid + amount }));
    addLog('EPURSE', `Liquidity Injection: +${amount} OPS`, 'SUCCESS');
    setShowDepositModal(false);
    setDepositAmount('');
  };

  const handleExchange = () => {
    if (!exchangeAmount) return;
    const amount = parseFloat(exchangeAmount);
    if (amount > ePurse.liquid) {
        addLog('EPURSE', 'Exchange failed: Insufficient funds.', 'ERROR');
        return;
    }
    BonasAPI.logRequest('GET', '/market/rates', 200);
    setEPurse(prev => ({ ...prev, liquid: prev.liquid - amount }));
    addLog('EPURSE', `Swapped ${amount} OPS for USDC.`, 'INFO');
    setShowExchangeModal(false);
    setExchangeAmount('');
  };

  // --- SIMULATION LOOP ---
  useEffect(() => {
    const interval = setInterval(() => {
      let newRisk = stochasticRisk;
      if (isFaultActive) newRisk = Math.min(100, newRisk + (Math.random() * 8));
      else newRisk = Math.max(12, newRisk - (Math.random() * 5));
      setStochasticRisk(newRisk);

      let currentSla = slaTarget;
      if (newRisk > 65 && slaTarget === 85) {
          currentSla = 75;
          setSlaTarget(75);
          addLog('HEURISTIC', 'Risk > 65%. Triggering Graceful Degradation. Target SLA lowered to 75%.', 'WARNING');
          if (agents.filter(a=>a.status === 'ACTIVE').length < 3) {
              setActiveBounties(prev => [...prev, { id: Date.now(), reward: 50, task: "Mitigate Entropy" }]);
              addLog('HEURISTIC', 'Local Entropy High. Broadcasting Swarm Bounty.', 'INFO');
          }
      } else if (newRisk < 40 && slaTarget === 75) {
          currentSla = 85;
          setSlaTarget(85);
          addLog('HEURISTIC', 'Risk normalized. Target SLA restored to Optimal (85%).', 'SUCCESS');
      }

      let currentEff = isFaultActive ? Math.random() * 20 + 40 : Math.random() * 5 + 90; 
      const activeOptimizers = agents.filter(a => a.status === 'ACTIVE' && a.type === 'OPTIMIZER');
      
      if (isFaultActive && activeOptimizers.length > 0) {
        let recoveryStep = 0;
        if (optStrategy === 'HEURISTIC') recoveryStep = activeOptimizers.length * 5; 
        else if (optStrategy === 'PID') recoveryStep = Math.max(2, Math.max(0, currentSla - currentEff) * 0.15 * activeOptimizers.length); 
        else if (optStrategy === 'EXTREMUM') recoveryStep = activeOptimizers.length * 25; 

        currentEff += recoveryStep; 
        
        if (currentEff >= currentSla) { 
            currentEff = Math.max(currentEff, currentSla + 2);
            setIsFaultActive(false); 
            addLog('OPTIMIZATION', `Fault resolved via ${optStrategy} logic meeting SLA (${currentSla}%).`, 'SUCCESS');
            if (faultStartTime) {
                const repairTime = (Date.now() - faultStartTime) / 1000;
                setMttr(prev => ((prev * 4) + repairTime) / 5); 
                setFaultStartTime(null);
                setAnomalies(prev => prev.map(a => a.status === 'ACTIVE' ? {...a, status: 'RESOLVED'} : a));
            }
        }
      }

      setEfficiencyData(prev => {
        const newData = [...prev, { time: generateTimeLabel(), efficiency: currentEff, baseline: currentSla }];
        if (newData.length > 20) newData.shift();
        return newData;
      });

      if (agents.length > 0) {
        let cycleRevenue = 0;
        let cycleGas = 0;
        
        setAgents(prev => prev.map(agent => {
            if (agent.status === 'ACTIVE') {
                let agentGas = 0.05;
                if (agent.type === 'OPTIMIZER') {
                    if (optStrategy === 'HEURISTIC') agentGas *= 0.5;
                    else if (optStrategy === 'EXTREMUM') agentGas *= 3.0;
                }
                cycleGas += agentGas;
                
                if (currentEff >= currentSla) {
                    let reward = agent.rewardRate;
                    if (newRisk > 50) reward *= 1.25; 
                    cycleRevenue += reward;
                    return { ...agent, earned: (agent.earned || 0) + reward, spent: (agent.spent || 0) + agentGas };
                }
                return { ...agent, spent: (agent.spent || 0) + agentGas };
            }
            return agent;
        }));

        setEPurse(prev => ({
            ...prev,
            liquid: prev.liquid + cycleRevenue - cycleGas,
            totalMined: prev.totalMined + cycleRevenue,
            gasBurned: prev.gasBurned + cycleGas
        }));
      }
    }, 1000);
    return () => clearInterval(interval);
  }, [agents, isFaultActive, faultStartTime, stochasticRisk, slaTarget, optStrategy]);


  // --- UI COMPONENT BLOCKS ---
  const GlassCard = ({ children, className = "", onClick }) => (
    <div onClick={onClick} className={`bg-black/30 backdrop-blur-xl border border-white/10 rounded-2xl shadow-xl ${className}`}>
      {children}
    </div>
  );

  const KPI = ({ label, value, sub, color, icon: Icon }) => (
    <GlassCard className={`p-4 md:p-6 relative overflow-hidden group border-l-4`} style={{borderLeftColor: color}}>
      <div className="absolute top-0 right-0 w-24 h-24 md:w-32 md:h-32 bg-white/5 rounded-full blur-2xl md:blur-3xl -mr-12 -mt-12 md:-mr-16 md:-mt-16 group-hover:bg-white/10 transition-all duration-500"></div>
      <div className="flex justify-between items-start relative z-10">
        <div>
          <div className="text-gray-400 text-[10px] uppercase font-bold tracking-widest mb-1 md:mb-2">{label}</div>
          <div className={`text-2xl md:text-3xl font-bold mb-0.5 md:mb-1 tracking-tight drop-shadow-md`} style={{ color }}>{value}</div>
          <div className="text-gray-500 text-[10px] md:text-xs font-medium">{sub}</div>
        </div>
        {Icon && <div className="p-2 md:p-3 bg-white/5 rounded-xl border border-white/10 text-gray-400"><Icon size={isMobileMode ? 16 : 20} /></div>}
      </div>
    </GlassCard>
  );

  const Modal = ({ title, isOpen, onClose, children }) => {
    if (!isOpen) return null;
    return (
      <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm animate-in fade-in duration-200">
        <GlassCard className={`w-full max-w-md p-6 border-indigo-500/30 bg-[#0a0a0f] max-h-[90vh] overflow-y-auto ${isMobileMode ? 'hide-scroll' : 'scrollbar-thin'}`}>
          <div className="flex justify-between items-center mb-6">
            <h3 className="text-lg md:text-xl font-bold text-white">{title}</h3>
            <button onClick={onClose} className="text-gray-400 hover:text-white"><X size={20} /></button>
          </div>
          {children}
        </GlassCard>
      </div>
    );
  };

  const radarData = [
    { subject: 'CPU', A: 120, fullMark: 150 },
    { subject: 'Memory', A: 98, fullMark: 150 },
    { subject: 'I/O', A: isFaultActive ? 140 : 60, fullMark: 150 },
    { subject: 'Power', A: isFaultActive ? 130 : 80, fullMark: 150 },
    { subject: 'Temp', A: isFaultActive ? 145 : 70, fullMark: 150 },
  ];

  // --- GEMINI FUNCTIONS ---
  const runAiStrategy = async () => {
    if (!apiKey) { setShowSettings(true); return; }
    setIsStrategizing(true);
    try {
      const currentEff = efficiencyData.length > 0 ? efficiencyData[efficiencyData.length-1].efficiency : 0;
      const agentSummary = agents.map(a => `${a.name} (${a.type})`).join(', ');
      const response = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{
              parts: [{
                text: `You are the Strategic Core of the BONAS system.
                Current Efficiency: ${currentEff.toFixed(1)}%
                Active Fault: ${isFaultActive ? 'Yes' : 'None'}
                Optimization Strategy: ${optStrategy}
                Wallet Balance: ${ePurse.liquid}
                Active Agents: ${agentSummary || "None"}
                
                Provide a short strategic recommendation (max 2 sentences). Suggest changing the Optimization Strategy if necessary.`
              }]
            }]
          })
        }
      );
      const data = await response.json();
      if (data.error) throw new Error(data.error.message || "API Error");
      const resultText = data.candidates?.[0]?.content?.parts?.[0]?.text;
      setStrategyAdvice(typeof resultText === 'string' ? resultText : "Strategy unavailable.");
    } catch (error) { setStrategyAdvice(`Strategic core offline: ${error.message}`); }
    setIsStrategizing(false);
  };

  const callGeminiAnalysisInternal = async (currentLogs, efficiency) => {
    try {
      const recentLogs = currentLogs.slice(0, 10).map(l => `${l.source}: ${l.message}`).join('\n');
      const response = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{
              parts: [{
                text: `You are the AI diagnostic core of the BONAS system. Analyze the following system state and provide a brief Root Cause Analysis (RCA) and a recommendation.
                
                Current Efficiency: ${Math.round(efficiency)}% (Baseline: 85%)
                Fault Active: ${isFaultActive ? 'Yes' : 'None'}
                Recent Logs:
                ${recentLogs}
                
                Keep response under 50 words. Focus on technical clarity.`
              }]
            }]
          })
        }
      );
      const data = await response.json();
