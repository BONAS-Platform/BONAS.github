                                            <div className="flex justify-between items-center">
                                                <span className="font-bold text-indigo-300 text-xs">{a.component}</span>
                                                <span className={`text-[9px] px-2 py-0.5 rounded font-bold ${a.status === 'ACTIVE' ? 'bg-red-500/20 text-red-400 animate-pulse' : 'bg-emerald-500/20 text-emerald-400'}`}>{a.status}</span>
                                            </div>
                                            <div className="flex justify-between items-end">
                                                <span className="text-gray-300 text-xs">{a.issue}</span>
                                                <span className="text-gray-500 font-mono text-[10px]">{a.time}</span>
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </GlassCard>
                        </div>
                    )}

                    {/* --- TAB: FORGE --- */}
                    {activeTab === 'forge' && (
                        <div className="space-y-4 md:space-y-6 animate-in fade-in zoom-in-95 duration-500">
                            
                            <div className="flex justify-between items-end">
                                <div><h1 className="text-3xl font-bold mb-2 text-white">Agent Forge & Studio</h1><p className="text-gray-400">Deploy existing templates or tokenize your own logic IP.</p></div>
                                <button onClick={() => setIsBuildingManual(!isBuildingManual)} className="bg-indigo-600/20 hover:bg-indigo-600/40 text-indigo-400 border border-indigo-500/30 px-4 py-2 rounded-xl text-sm font-bold flex items-center gap-2 transition-all"><Code2 size={16} /> Developer Studio</button>
                            </div>

                            {/* DEV STUDIO / MINTING UI */}
                            {isBuildingManual && (
                                <GlassCard className="p-0 mb-8 border-indigo-500/50 animate-in fade-in slide-in-from-top-4 overflow-hidden">
                                    <div className="bg-indigo-900/40 p-4 border-b border-indigo-500/30 flex justify-between items-center">
                                        <h3 className="font-bold text-white text-lg flex items-center gap-2"><PenTool size={18} className="text-indigo-400"/> ebot IP Tokenization Studio</h3>
                                        <button onClick={() => setIsBuildingManual(false)} className="text-gray-500 hover:text-white"><X size={20} /></button>
                                    </div>
                                    <div className="p-6 grid grid-cols-1 md:grid-cols-2 gap-8">
                                        <div className="space-y-4">
                                            <h4 className="text-sm font-bold text-indigo-300 border-b border-white/10 pb-2">1. Define Logic & Identity</h4>
                                            <div className="grid grid-cols-2 gap-4">
                                                <div><label className="block text-gray-400 text-[10px] uppercase tracking-wider font-bold mb-1">Agent Name</label><input type="text" className="w-full bg-black/40 border border-white/10 rounded-lg p-2.5 text-sm text-white focus:border-indigo-500 outline-none" value={manualAgent.name} onChange={e => setManualAgent({...manualAgent, name: e.target.value})} placeholder="e.g. CacheClearer" /></div>
                                                <div><label className="block text-gray-400 text-[10px] uppercase tracking-wider font-bold mb-1">Type</label><select className="w-full bg-black/40 border border-white/10 rounded-lg p-2.5 text-sm text-white focus:border-indigo-500 outline-none" value={manualAgent.type} onChange={e => setManualAgent({...manualAgent, type: e.target.value})}><option value="OPTIMIZER">Optimizer</option><option value="DIAGNOSTIC">Diagnostic</option><option value="HARVESTER">Harvester</option></select></div>
                                            </div>
                                            <div><label className="block text-gray-400 text-[10px] uppercase tracking-wider font-bold mb-1">Heuristic Logic (Pseudo-code)</label><textarea className="w-full h-32 bg-black/60 border border-white/10 rounded-lg p-3 text-xs text-emerald-400 font-mono focus:border-indigo-500 outline-none resize-none" value={manualAgent.logic} onChange={e => setManualAgent({...manualAgent, logic: e.target.value})} /></div>
                                        </div>
                                        <div className="space-y-4">
                                            <h4 className="text-sm font-bold text-indigo-300 border-b border-white/10 pb-2">2. Tokenomics & Minting</h4>
                                            <div className="grid grid-cols-2 gap-4">
                                                <div><label className="block text-gray-400 text-[10px] uppercase tracking-wider font-bold mb-1">Stake Required (OPS)</label><input type="number" className="w-full bg-black/40 border border-white/10 rounded-lg p-2.5 text-sm text-white focus:border-indigo-500 outline-none" value={manualAgent.cost} onChange={e => setManualAgent({...manualAgent, cost: e.target.value})} /></div>
                                                <div><label className="block text-gray-400 text-[10px] uppercase tracking-wider font-bold mb-1">Base Reward Rate</label><input type="number" step="0.1" className="w-full bg-black/40 border border-white/10 rounded-lg p-2.5 text-sm text-white focus:border-indigo-500 outline-none" value={manualAgent.rewardRate} onChange={e => setManualAgent({...manualAgent, rewardRate: e.target.value})} /></div>
                                                <div><label className="block text-gray-400 text-[10px] uppercase tracking-wider font-bold mb-1">Creator Royalty (%)</label><input type="number" className="w-full bg-black/40 border border-amber-500/30 rounded-lg p-2.5 text-sm text-amber-400 focus:border-amber-500 outline-none" value={manualAgent.royalty} onChange={e => setManualAgent({...manualAgent, royalty: e.target.value})} /></div>
                                                <div><label className="block text-gray-400 text-[10px] uppercase tracking-wider font-bold mb-1">Theme Color</label><input type="color" className="w-full h-10 bg-black/40 border border-white/10 rounded-lg p-1 cursor-pointer" value={manualAgent.color} onChange={e => setManualAgent({...manualAgent, color: e.target.value})} /></div>
                                            </div>
                                            <div className="pt-4 flex gap-3">
                                                <div className="flex-1 bg-white/5 border border-white/10 rounded-xl p-3 flex flex-col justify-center items-center">
                                                    <span className="text-[10px] text-gray-400 uppercase">Registration Fee</span>
                                                    <span className="font-mono font-bold text-white">25.00 OPS</span>
                                                </div>
                                                <button onClick={handleTestAndMint} disabled={isTestingEbot} className="flex-[2] bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 rounded-xl text-white font-bold flex flex-col justify-center items-center transition-all disabled:opacity-50">
                                                    {isTestingEbot ? <span className="animate-spin"><Loader2 size={20}/></span> : <><Fingerprint size={18} className="mb-1"/> <span>Simulate & Mint IP</span></>}
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </GlassCard>
                            )}

                            {activeBounties.length > 0 && (
                                <GlassCard className="p-5 border-amber-500/40 bg-amber-500/10">
                                    <h3 className="font-bold text-amber-400 mb-3 flex items-center gap-2"><Radio size={18}/> Network Bounties Available</h3>
                                    {activeBounties.map(b => (
                                        <div key={b.id} className="flex justify-between items-center bg-black/40 p-3 rounded-lg border border-amber-500/20">
                                            <div>
                                                <div className="font-bold text-white text-sm">{b.task}</div>
                                                <div className="text-xs text-gray-400">High Local Entropy - Immediate Assistance Required</div>
                                            </div>
                                            <div className="text-right">
                                                <div className="text-amber-400 font-mono font-bold">+{b.reward} OPS</div>
                                                <div className="text-[9px] uppercase tracking-wider text-gray-500">Volatility Premium</div>
                                            </div>
                                        </div>
                                    ))}
                                </GlassCard>
                            )}

                            <GlassCard className="p-5 md:p-8 bg-gradient-to-r from-indigo-900/20 to-purple-900/20 border-indigo-500/30">
                                <div className="flex items-center gap-2 mb-4"><Sparkles className="text-indigo-400" size={18}/> <h3 className="font-bold text-white text-base md:text-lg">AI Architect</h3></div>
                                <div className={`flex gap-3 ${isMobileMode ? 'flex-col' : ''}`}>
                                    <input type="text" value={aiPrompt} onChange={(e) => setAiPrompt(e.target.value)} placeholder="Describe agent logic..." className="flex-1 bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:border-indigo-500 outline-none" />
                                    <button onClick={handleAiGeneration} disabled={isGeneratingAgent} className="bg-indigo-600 px-6 py-3 rounded-xl font-bold text-sm text-white flex justify-center items-center gap-2 w-full md:w-auto">
                                        {isGeneratingAgent ? <span className="animate-spin">⟳</span> : 'Generate'}
                                    </button>
                                </div>
                            </GlassCard>

                            <div className={`grid gap-4 md:gap-6 ${isMobileMode ? 'grid-cols-1' : 'grid-cols-3'}`}>
                                {agentTemplates.map((tpl) => (
                                    <GlassCard key={tpl.id} onClick={() => setSelectedTemplate(tpl)} className={`p-5 cursor-pointer transition-all ${selectedTemplate?.id === tpl.id ? 'border-indigo-500 bg-indigo-500/10' : 'hover:border-white/20'}`}>
                                        <div className="flex justify-between items-start mb-4">
                                            <div className="w-10 h-10 md:w-12 md:h-12 rounded-xl flex items-center justify-center" style={{ backgroundColor: `${tpl.color}15`, color: tpl.color, border: `1px solid ${tpl.color}30` }}><Cpu size={isMobileMode ? 20 : 24} /></div>
                                            {tpl.creator !== 'System' && <span className="bg-amber-500/20 text-amber-400 border border-amber-500/30 text-[9px] px-2 py-0.5 rounded-full font-bold flex items-center gap-1"><Fingerprint size={10}/> IP: {tpl.creator}</span>}
                                        </div>
                                        <h3 className="font-bold text-base md:text-lg text-white mb-1">{tpl.name}</h3>
                                        <div className="text-[10px] md:text-xs font-mono text-gray-500 mb-4">{tpl.type} • {tpl.target}</div>
                                        <div className="space-y-1">
                                            <div className="flex justify-between text-xs bg-white/5 p-2 rounded text-gray-300"><span>Stake Cost</span><span className="font-bold text-white">{tpl.cost} OPS</span></div>
                                            <div className="flex justify-between text-xs bg-white/5 p-2 rounded text-gray-300"><span>Reward Rate</span><span className="font-bold text-emerald-400">+{tpl.rewardRate}/cyc</span></div>
                                            {tpl.royalty > 0 && <div className="flex justify-between text-[10px] bg-amber-500/5 p-2 rounded text-amber-500/80"><span>Creator Royalty</span><span className="font-bold">{tpl.royalty}%</span></div>}
                                        </div>
                                    </GlassCard>
                                ))}
                            </div>
                        </div>
                    )}

                    {/* --- TAB: EPURSE --- */}
                    {activeTab === 'epurse' && (
                        <div className="space-y-4 md:space-y-8 animate-in fade-in zoom-in-95 duration-500">
                            <GlassCard className="p-6 md:p-10 relative overflow-hidden bg-gradient-to-br from-indigo-900/40 to-black/40 border-indigo-500/30">
                                <div className="absolute top-0 right-0 p-4 opacity-10"><CreditCard size={isMobileMode ? 80 : 160} /></div>
                                <h2 className="text-gray-400 uppercase tracking-widest font-bold text-[10px] md:text-xs mb-2">Total Liquid Assets</h2>
                                <div className="text-5xl md:text-7xl font-bold text-white mb-6 md:mb-8 tracking-tight">{ePurse.liquid.toFixed(2)} <span className="text-2xl md:text-4xl text-indigo-400 font-normal">OPS</span></div>
                                <div className={`flex gap-3 md:gap-4 ${isMobileMode ? 'flex-col' : ''}`}>
                                    <button onClick={() => setShowDepositModal(true)} className="bg-white text-black px-5 py-3 md:px-8 md:py-4 rounded-xl font-bold hover:bg-gray-200 transition-colors flex items-center justify-center gap-2"><Plus size={18} /> Deposit</button>
                                    <button onClick={() => setShowExchangeModal(true)} className="bg-white/10 text-white border border-white/10 px-5 py-3 md:px-8 md:py-4 rounded-xl font-bold hover:bg-white/20 transition-colors flex items-center justify-center gap-2"><ArrowRightLeft size={18} /> Exchange</button>
                                </div>
                            </GlassCard>

                            <div className={`grid gap-4 md:gap-8 ${isMobileMode ? 'grid-cols-1' : 'grid-cols-2'}`}>
                                <GlassCard className="p-6 bg-emerald-900/10 border-emerald-500/20">
                                    <div className="flex items-center gap-3 mb-4"><div className="p-2 bg-emerald-500/20 rounded-lg text-emerald-400"><Lock size={18} /></div><div><div className="text-xs text-gray-400 font-bold uppercase">Total Staked</div></div></div>
                                    <div className="text-3xl font-bold text-white mb-2">{ePurse.staked.toFixed(2)}</div>
                                    <div className="w-full bg-black/40 rounded-full h-1.5 mt-2"><div className="bg-emerald-500 h-full rounded-full" style={{ width: '65%' }}></div></div>
                                </GlassCard>
                                <GlassCard className="p-6">
                                    <div className="flex items-center gap-3 mb-4"><div className="p-2 bg-amber-500/20 rounded-lg text-amber-400"><Zap size={18} /></div><div><div className="text-xs text-gray-400 font-bold uppercase">Lifetime Mined</div></div></div>
                                    <div className="text-3xl font-bold text-white mb-2">{ePurse.totalMined.toFixed(2)}</div>
                                    <div className="text-xs text-red-400 font-mono mt-2">- {ePurse.gasBurned.toFixed(2)} (Gas Burned)</div>
                                </GlassCard>
                            </div>
                        </div>
                    )}
                    
                    {/* --- TAB: LOGS --- */}
                    {activeTab === 'logs' && (
                        <div className="space-y-4 md:space-y-6 animate-in fade-in zoom-in-95 duration-500 h-full">
                            <GlassCard className="p-0 flex flex-col h-full min-h-[60vh] overflow-hidden">
                                <div className={`flex justify-between items-center p-4 border-b border-white/5 bg-black/20 overflow-x-auto ${isMobileMode ? 'hide-scroll' : ''}`}>
                                    <div className="flex items-center gap-4 shrink-0">
                                        <span className="text-gray-400 font-bold text-xs tracking-widest flex items-center gap-2"><Terminal size={14} /> LEDGER</span>
                                        <div className="flex gap-1">
                                            {['ALL', 'ERROR', 'SUCCESS', 'OPTIMIZATION', 'HEURISTIC'].map(f => (
                                                <button key={f} onClick={() => setLogFilter(f)} className={`text-[10px] px-2 py-0.5 rounded border transition-colors ${logFilter === f ? 'bg-white/10 text-white border-white/20' : 'text-gray-500 border-transparent hover:text-gray-300'}`}>{f}</button>
                                            ))}
                                        </div>
                                    </div>
                                </div>
                                <div className={`overflow-y-auto flex-1 p-4 font-mono text-xs space-y-1 ${isMobileMode ? 'hide-scroll' : 'scrollbar-thin scrollbar-thumb-white/10'}`}>
                                    {logs.filter(log => logFilter === 'ALL' || log.type === logFilter || log.source === logFilter).map((log) => (
                                        <div key={log.id} className="flex gap-3 hover:bg-white/5 p-1 rounded transition-colors">
                                            <span className="text-gray-600 shrink-0">[{log.time}]</span>
                                            <span className={`font-bold shrink-0 ${
                                                log.type === 'ERROR' ? 'text-red-400' : 
                                                log.type === 'SUCCESS' ? 'text-emerald-400' : 
                                                log.type === 'WARNING' ? 'text-amber-400' : 
                                                log.source === 'OPTIMIZATION' ? 'text-cyan-400' : 
                                                log.source === 'HEURISTIC' ? 'text-purple-400' : 'text-indigo-400'
                                            }`}>{log.source}</span>
                                            <span className="text-gray-300">{log.message}</span>
                                        </div>
                                    ))}
                                    <div ref={logEndRef} />
                                </div>
                            </GlassCard>
                        </div>
                    )}
                </main>

                {/* MOBILE BOTTOM NAVIGATION */}
                {isMobileMode && (
                    <div className="fixed bottom-0 left-0 right-0 bg-[#0a0a0f]/95 backdrop-blur-2xl border-t border-white/10 flex justify-around items-center p-2 pb-safe z-40 rounded-b-[2.5rem]">
                        {[
                            { id: 'dashboard', icon: Activity, label: 'Dash' },
                            { id: 'diagnostics', icon: ShieldAlert, label: 'Risk' },
                            { id: 'forge', icon: Cpu, label: 'Forge' },
                            { id: 'epurse', icon: Wallet, label: 'Wallet' },
                            { id: 'logs', icon: Terminal, label: 'Logs' }
                        ].map(item => (
                            <button 
                                key={item.id} 
                                onClick={() => setActiveTab(item.id)} 
                                className={`flex flex-col items-center justify-center p-2 w-14 transition-all ${activeTab === item.id ? 'text-indigo-400 -translate-y-1' : 'text-gray-500'}`}
                            >
                                <item.icon size={22} className={activeTab === item.id ? 'drop-shadow-[0_0_8px_rgba(99,102,241,0.8)]' : ''} />
                                <span className="text-[9px] mt-1 font-medium">{item.label}</span>
                            </button>
                        ))}
                    </div>
                )}
            </div>
        </div>

        {/* --- MODALS --- */}
        <Modal title="Deploy Agent" isOpen={!!selectedTemplate} onClose={() => setSelectedTemplate(null)}>
            {selectedTemplate && (
                <div className="space-y-6">
                    <div className="flex items-center gap-4 bg-black/40 p-4 rounded-xl border border-white/5">
                        <Cpu className="text-indigo-400" size={32} />
                        <div><div className="font-bold text-white">{selectedTemplate.name}</div><div className="text-xs text-gray-500">Requires {selectedTemplate.cost} OPS Stake</div></div>
                    </div>
                    <button onClick={() => { deployAgent(selectedTemplate); setSelectedTemplate(null); setActiveTab('dashboard'); }} className="w-full bg-indigo-600 hover:bg-indigo-500 py-3 rounded-xl font-bold text-white shadow-lg transition-all">Confirm & Deploy</button>
                </div>
            )}
        </Modal>

        <Modal title="Agent Analytics" isOpen={!!selectedActiveAgent} onClose={() => setSelectedActiveAgent(null)}>
            {selectedActiveAgent && (
                <div className="space-y-4">
                    <div className="grid grid-cols-2 gap-4">
                        <div className="bg-white/5 p-4 rounded-xl border border-white/10"><div className="text-[10px] text-gray-400 uppercase tracking-widest mb-1">Mined</div><div className="text-xl font-bold text-emerald-400">{(selectedActiveAgent.earned || 0).toFixed(2)}</div></div>
                        <div className="bg-white/5 p-4 rounded-xl border border-white/10"><div className="text-[10px] text-gray-400 uppercase tracking-widest mb-1">Spent</div><div className="text-xl font-bold text-red-400">{(selectedActiveAgent.spent || 0).toFixed(2)}</div></div>
                    </div>
                    <div className="space-y-2 pt-2 border-t border-white/10">
                        <button onClick={() => handleRetireAgent(selectedActiveAgent)} className="w-full bg-red-900/20 text-red-400 border border-red-500/30 py-3 rounded-xl font-bold flex justify-center items-center gap-2"><PowerOff size={18} /> Retire Agent (+{selectedActiveAgent.cost} Refund)</button>
                    </div>
                </div>
            )}
        </Modal>

        <Modal title="Settings" isOpen={showSettings} onClose={() => setShowSettings(false)}>
            <div className="space-y-4">
                <div><label className="block text-gray-400 text-xs font-bold mb-2">Gemini API Key</label><input type="password" className="w-full bg-black/40 border border-white/10 rounded-lg p-3 text-sm text-white outline-none" value={apiKey} onChange={e => setApiKey(e.target.value)} placeholder="API Key..." /></div>
                <button onClick={() => saveApiKey(apiKey)} className="w-full bg-indigo-600 py-3 rounded-lg text-white font-bold">Save</button>
            </div>
        </Modal>

        <Modal title="Deposit Liquidity" isOpen={showDepositModal} onClose={() => setShowDepositModal(false)}>
            <div className="space-y-4">
                <input type="number" className="w-full bg-black/40 border border-white/10 rounded-lg p-3 text-white outline-none" value={depositAmount} onChange={e => setDepositAmount(e.target.value)} placeholder="Amount in OPS" />
                <button onClick={handleDeposit} className="w-full bg-emerald-600 py-3 rounded-lg text-white font-bold">Confirm</button>
            </div>
        </Modal>

        <Modal title="Exchange" isOpen={showExchangeModal} onClose={() => setShowExchangeModal(false)}>
            <div className="space-y-4">
                <input type="number" className="w-full bg-black/40 border border-white/10 rounded-lg p-3 text-white outline-none" value={exchangeAmount} onChange={e => setExchangeAmount(e.target.value)} placeholder="Amount to Sell" />
                <button onClick={handleExchange} className="w-full bg-indigo-600 py-3 rounded-lg text-white font-bold">Swap for USDC</button>
            </div>
        </Modal>

    </div>
  );
}

const PickaxeIcon = ({size, className}) => (<svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><path d="M14.5 5.5l4 4" /><path d="M3 21l9-9" /><path d="M13 6.5l4.5 4.5" /><path d="M19 5l1.5 1.5" /><path d="M16 3l5 5" /><path d="M2 22l6.5-6.5" /></svg>);
